# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://elctro_user:elctro_pass@localhost:5432/elctro_db"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -hex 64
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Token time-to-live (ms-compatible strings via jsonwebtoken: 15m, 7d, etc.)
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"

# The Next.js origin — used for CORS and Secure cookie logic
FRONTEND_ORIGIN="http://localhost:3000"

# Public base URL for OpenAPI "servers" (Swagger UI). Omit to use http://localhost:<PORT>
# API_PUBLIC_URL="https://api.example.com"
