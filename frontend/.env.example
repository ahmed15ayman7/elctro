# Server-side URL for Server Actions (same host as browser in dev: localhost:4000)
API_BASE_URL=http://localhost:4000

# Browser Socket.io endpoint (must be reachable from the client; dev default matches Express)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Cookie max-age should match backend JWT TTL (same strings as backend .env)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
