# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=elctro_user
POSTGRES_PASSWORD=elctro_pass
POSTGRES_DB=elctro_db

# ─── JWT (generate: openssl rand -hex 64) ────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-in-production
JWT_REFRESH_SECRET=change-me-refresh-secret-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
FRONTEND_ORIGIN=http://localhost:3000
